{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "磁盘清理帮手",
  "version": "1.0.0",
  "identifier": "com.taoint.diskmanager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "磁盘清理帮手 By Taoist v1.0.0",
        "width": 1080,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}